    setFormValues(values);
    setOriginalValues(values); // 🔥 حفظ القيم الأصلية
    setFormErrors({});
  }
};

  const toggleAdd = () => {
    if (isAdding) {
      setIsAdding(false);
      setFormValues({});
      setFormErrors({});
    } else {
      setIsAdding(true);
      setFormValues({
        full_name: '',
        phone: '',
        date: '',
        time: '',
