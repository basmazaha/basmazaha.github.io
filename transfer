// Edge Function: send-appointment-reminders
// الغرض: إرسال تذكير قبل ~6 ساعات من الموعد عبر Brevo
// يعتمد على date_time المخزن UTC
// cron يعمل كل ساعة
// ────────────────────────────────────────────────────────────────

const BREVO_API_KEY   = Deno.env.get("BREVO_API_KEY");
const APP_BASE_URL    = (Deno.env.get("APP_BASE_URL") || "https://new-91v.pages.dev/").replace(/\/+$/, "");
const REMINDER_SECRET = Deno.env.get("REMINDER_SECRET");

if (!BREVO_API_KEY || !REMINDER_SECRET) {
  console.error("Missing required environment variables");
  Deno.serve(() => new Response(
    JSON.stringify({ error: "Server misconfiguration – missing env vars" }),
    { status: 500, headers: { "Content-Type": "application/json" } }
  ));
}

Deno.serve(async (req: Request) => {

  if (req.headers.get("x-reminder-secret") !== REMINDER_SECRET) {
    return new Response("Unauthorized", { status: 401 });
  }

  if (req.method !== "POST") {
    return new Response("Method Not Allowed", { status: 405 });
  }

  const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2");
  const { DateTime } = await import("https://esm.sh/luxon");

  const supabase = createClient(
    Deno.env.get("SUPABASE_URL")!,
    Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!
  );

  // ─────────────────────────────────────────
  // جلب timezone من إعدادات العيادة
  // ─────────────────────────────────────────

  const { data: settings } = await supabase
    .from("business_settings")
    .select("timezone")
    .single();

  const BUSINESS_TZ = settings?.timezone || "Africa/Cairo";

  // ─────────────────────────────────────────
  // حساب نافذة التذكير (6 ساعات)
  // cron يعمل كل ساعة
  // ─────────────────────────────────────────

  const nowUTC = DateTime.utc();

  const startWindow = nowUTC.plus({ hours: 6 });
  const endWindow   = nowUTC.plus({ hours: 7 });

  // ─────────────────────────────────────────
  // جلب المواعيد
  // ─────────────────────────────────────────

  const { data: appointments, error } = await supabase
    .from("appointments")
    .select(`
      id,
      full_name,
      email,
      date_time,
      reason,
      manage_token
    `)
    .eq("reminder_sent_6h", false)
    .not("email", "is", null)
    .in("status", ["confirmed", "rescheduled"])
    .gte("date_time", startWindow.toISO())
    .lt("date_time", endWindow.toISO())
    .order("date_time", { ascending: true });

  if (error) {
    console.error("Supabase error:", error);

    return new Response(
      JSON.stringify({ error: "فشل الاستعلام من قاعدة البيانات" }),
      { status: 500, headers: { "Content-Type": "application/json" } }
    );
  }

  if (!appointments || appointments.length === 0) {
    return new Response(
      JSON.stringify({ message: "لا توجد تذكيرات مستحقة الآن" }),
      { status: 200, headers: { "Content-Type": "application/json" } }
    );
  }

  const sentIds : string[] = [];
  const failedIds : string[] = [];

  // ─────────────────────────────────────────
  // إرسال التذكيرات
  // ─────────────────────────────────────────

  for (const ap of appointments) {

    try {

      const localDate = DateTime
        .fromISO(ap.date_time, { zone: "utc" })
        .setZone(BUSINESS_TZ);

      const formattedDateAr = localDate
        .setLocale("ar-EG")
        .toLocaleString(DateTime.DATE_FULL);

      const formattedTimeAr = localDate
        .setLocale("ar-EG")
        .toFormat("hh:mm a");

      const formattedTimeEn = localDate
        .setLocale("en-US")
        .toFormat("hh:mm a");

      const manageLinkAr = `${APP_BASE_URL}/manage/${ap.manage_token}`;
      const manageLinkEn = `${APP_BASE_URL}/en/manage/${ap.manage_token}`;

      const htmlContent = `
<div dir="rtl" style="font-family: Tahoma, Arial, sans-serif; max-width: 620px; margin: 0 auto; padding: 24px; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px;">
  <h2 style="color: #1a3c5e; text-align: center; margin-bottom: 24px;">تذكير بموعدك القادم</h2>
  <p style="font-size: 16px; color: #333; line-height: 1.6;">مرحباً ${ap.full_name || "السيد/السيدة"}،</p>
  <p style="font-size: 16px; color: #333; line-height: 1.6;"> هذا تذكير بموعدك اليوم في عيادة دكتور عمرو لطب وتجميل الاسنان: </p>

  <table style="width:100%; margin:20px 0; border-collapse:collapse;">
    <tr><td style="padding:12px; background:#f8f9fa; font-weight:bold; width:140px; border:1px solid #e0e0e0;">الاسم</td><td style="padding:12px; border:1px solid #e0e0e0;">${ap.full_name || "غير محدد"}</td></tr>
    <tr><td style="padding:12px; background:#f8f9fa; font-weight:bold; border:1px solid #e0e0e0;">التاريخ</td><td style="padding:12px; border:1px solid #e0e0e0;">${formattedDateAr || "غير محدد"}</td></tr>
