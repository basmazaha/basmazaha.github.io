// ────────────────────────────────────────────────────────────────
// Edge Function: send-appointment-reminders
// الغرض: إرسال تذكير قبل ~6 ساعات من الموعد عبر Brevo
// ملاحظة: appointment_time مخزن بالتوقيت المحلي (مصر) مباشرة
// ────────────────────────────────────────────────────────────────

const BREVO_API_KEY   = Deno.env.get("BREVO_API_KEY");
const APP_BASE_URL    = (Deno.env.get("APP_BASE_URL") || "https://new-91v.pages.dev/").replace(/\/+$/, "");
const REMINDER_SECRET = Deno.env.get("REMINDER_SECRET");

// توقيت مصر – نستخدمه فقط للمقارنات الزمنية الدقيقة إذا لزم الأمر
const EGYPT_TZ = "Africa/Cairo";

if (!BREVO_API_KEY || !REMINDER_SECRET) {
  console.error("Missing required environment variables");
  Deno.serve(() => new Response(
    JSON.stringify({ error: "Server misconfiguration – missing env vars" }),
    { status: 500, headers: { "Content-Type": "application/json" } }
  ));
}

Deno.serve(async (req: Request) => {
  // حماية بسيطة ضد الاستدعاء غير المصرح
  if (req.headers.get("x-reminder-secret") !== REMINDER_SECRET) {
    return new Response("Unauthorized", { status: 401 });
  }

  if (req.method !== "POST") {
    return new Response("Method Not Allowed", { status: 405 });
  }

  // ────────────────────────────────────────────────
  // إعداد Supabase client
  // ────────────────────────────────────────────────
  const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2");

  const supabase = createClient(
    Deno.env.get("SUPABASE_URL")!,
    Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!
  );

  // ────────────────────────────────────────────────
  // إعداد Luxon للتعامل مع التواريخ والتوقيتات بشكل صحيح
  // ────────────────────────────────────────────────
  const { DateTime } = await import("https://esm.sh/luxon");

  // ────────────────────────────────────────────────
  // دالة لتنسيق التاريخ بالصيغة العربية (مصر)
  // ────────────────────────────────────────────────
  function formatArabicDate(isoDate: string | null | undefined): string | null {
    if (!isoDate || !/^\d{4}-\d{2}-\d{2}$/.test(isoDate)) return null;

    const date = DateTime.fromISO(isoDate, { zone: EGYPT_TZ });
    if (!date.isValid) return null;

    return date.toLocaleString({ year: 'numeric', month: 'long', day: 'numeric' }, { locale: 'ar-EG' });
  }

  // ────────────────────────────────────────────────
  // حساب النافذة الزمنية الحالية (محلي – مصر)
  // ────────────────────────────────────────────────
  const now = DateTime.now().setZone(EGYPT_TZ);

  const sixHoursLater = now.plus({ hours: 6 });
  const windowEnd     = now.plus({ hours: 6, minutes: 15 });

  // ────────────────────────────────────────────────
  // جلب المواعيد المرشحة (التي لم يُرسل لها تذكير بعد)
  // ────────────────────────────────────────────────
  const { data: appointments, error } = await supabase
    .from("appointments")
    .select(`
      id,
      full_name,
      email,
      appointment_date,
      appointment_time,
      reason,
      manage_token,
      reminder_sent_6h
    `)
    .eq("reminder_sent_6h", false)
    .gte("appointment_date", now.toISODate())
    .lte("appointment_date", sixHoursLater.toISODate())
    .order("appointment_date", { ascending: true });

  if (error) {
    console.error("Supabase fetch error:", error);
    return new Response(
      JSON.stringify({ error: "فشل الاستعلام من قاعدة البيانات" }),
      { status: 500, headers: { "Content-Type": "application/json" } }
    );
  }

  if (!appointments || appointments.length === 0) {
    return new Response(
      JSON.stringify({ message: "لا توجد تذكيرات مستحقة الآن" }),
      { status: 200, headers: { "Content-Type": "application/json" } }
    );
  }

  const sent   : string[] = [];
  const failed : string[] = [];

  for (const ap of appointments) {
    try {
      // ────────────────────────────────────────────────
      // بناء وقت الموعد بالتوقيت المحلي (كما مخزن في الجدول)
      // ────────────────────────────────────────────────
      const timeStr = ap.appointment_time?.trim() || "00:00:00";
      const dateTimeStr = `${ap.appointment_date}T${timeStr.padEnd(8, ":00")}`;

      const appointmentLocal = DateTime.fromISO(dateTimeStr, { zone: EGYPT_TZ });
      if (!appointmentLocal.isValid) {
        throw new Error("Invalid appointment date/time");
      }

      // تجاهل إذا كان خارج النافذة
      if (appointmentLocal < now || appointmentLocal > windowEnd) {
        continue;
      }

      // ────────────────────────────────────────────────
      // تنسيق الوقت للعرض
      // ────────────────────────────────────────────────
      let formattedTimeAr = "غير محدد";
      let formattedTimeEn = "Not specified";

      if (ap.appointment_time && ap.appointment_time.trim() !== "") {
        const cleanTime = ap.appointment_time.slice(0, 5); // HH:MM
        const dummyDate = DateTime.fromISO(`1970-01-01T${cleanTime}:00`, { zone: EGYPT_TZ });

        formattedTimeAr = dummyDate.toFormat('hh:mm a', { locale: 'ar-EG' });
        formattedTimeEn = dummyDate.toFormat('hh:mm a', { locale: 'en-US' });
      }

      // ────────────────────────────────────────────────
      // روابط إدارة الحجز
      // ────────────────────────────────────────────────
      const manageLinkAr = `${APP_BASE_URL}/manage/${ap.manage_token}`;
      const manageLinkEn = `${APP_BASE_URL}/en/manage/${ap.manage_token}`;

      // ────────────────────────────────────────────────
      // محتوى الإيميل (تذكير)
      // ────────────────────────────────────────────────
      const htmlContent = `
<div dir="rtl" style="font-family: Tahoma, Arial, sans-serif; max-width: 620px; margin: 0 auto; padding: 24px; background: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px;">
  <h2 style="color: #1a3c5e; text-align: center; margin-bottom: 24px;">تذكير بموعدك القادم</h2>
  <p style="font-size: 16px; color: #333; line-height: 1.6;">مرحباً ${ap.full_name || "السيد/السيدة"}،</p>
  <p style="font-size: 16px; color: #333; line-height: 1.6;"> هذا تذكير بموعدك اليوم في عيادة دكتور عمرو لطب وتجميل الاسنان: </p>

