// supabase/functions/check-booked-times/index.ts

import { createClient } from "npm:@supabase/supabase-js@2.29.0";

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
  "Access-Control-Allow-Methods": "POST, OPTIONS",
};

const SUPABASE_URL = Deno.env.get("SUPABASE_URL");
const SUPABASE_SERVICE_ROLE_KEY = Deno.env.get("SUPABASE_SERVICE_ROLE_KEY");

const supabase = createClient(SUPABASE_URL ?? "", SUPABASE_SERVICE_ROLE_KEY ?? "", {
  auth: { persistSession: false },
  global: { headers: { "x-client-info": "check-booked-times" } },
});

Deno.serve(async (req: Request) => {
  // ─── التعامل مع طلب OPTIONS (preflight) ───
  if (req.method === "OPTIONS") {
    return new Response(null, { headers: corsHeaders });
  }

  // ─── رفض أي طريقة غير POST ───
  if (req.method !== "POST") {
    return new Response("Method Not Allowed", { status: 405, headers: corsHeaders });
  }

  // ─── قراءة الـ body ───
  let body;
  try {
    body = await req.json();
  } catch {
    return new Response(JSON.stringify({ error: "Bad JSON body" }), {
      status: 400,
      headers: { ...corsHeaders, "Content-Type": "application/json" },
    });
  }

  const { query_type = "booked_times", date, days = 15 } = body ?? {};

  // التحقق من صيغة التاريخ إذا وُجد
  if (date && (typeof date !== "string" || !/^\d{4}-\d{2}-\d{2}$/.test(date))) {
    return new Response(
      JSON.stringify({ error: "التاريخ غير صالح أو مفقود" }),
      { status: 400, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  }

  try {
    // 1. جلب الأيام المعطلة
    if (query_type === "off_days") {
      const { data, error } = await supabase
        .from("off_days")
        .select("date")
        .gte("date", new Date().toISOString().split("T")[0])
        .order("date", { ascending: true });

      if (error) throw error;

      const off_days = (data || []).map(row => row.date);
      return new Response(JSON.stringify({ off_days }), {
        status: 200,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    // 2. ساعات العمل ليوم معين (ديناميكي من working_hours)
    if (query_type === "working_hours_for_date") {
      if (!date) {
        return new Response(JSON.stringify({ error: "التاريخ مطلوب" }), {
          status: 400,
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        });
      }

      const d = new Date(date);
      const dow = d.getDay();

      const { data, error } = await supabase
        .from("working_hours")
        .select("is_closed, start_time, end_time, slot_duration_minutes, break_start, break_end")
        .eq("day_of_week", dow)
        .maybeSingle();

      if (error) throw error;
      if (!data || data.is_closed) {
        return new Response(JSON.stringify({ error: "اليوم مغلق" }), {
          status: 200,
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        });
      }

      return new Response(JSON.stringify({
        start_time: data.start_time,
        end_time: data.end_time,
        slot_duration_minutes: data.slot_duration_minutes || 15,
        break_start: data.break_start,
        break_end: data.break_end,
      }), {
        status: 200,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    // 3. التواريخ المتاحة في الأيام القادمة (مع التحقق من working_hours)
    if (query_type === "available_dates_next_days") {
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const futureDate = new Date(today);
      futureDate.setDate(today.getDate() + days);

      const { data: offData } = await supabase
        .from("off_days")
        .select("date")
        .gte("date", today.toISOString().split("T")[0])
        .lte("date", futureDate.toISOString().split("T")[0]);

      const offDaysSet = new Set(offData?.map(r => r.date) || []);

      const { data: hoursData } = await supabase
        .from("working_hours")
        .select("day_of_week, is_closed");

      const openDays = new Set(
        hoursData?.filter(h => !h.is_closed).map(h => h.day_of_week) || []
      );

      const availableDates: string[] = [];

      for (let i = 0; i < days; i++) {
        const current = new Date(today);
        current.setDate(today.getDate() + i);
        const dateStr = current.toISOString().split("T")[0];
        const dow = current.getDay();

        if (offDaysSet.has(dateStr)) continue;
        if (!openDays.has(dow)) continue;

        availableDates.push(dateStr);
      }

      return new Response(JSON.stringify({ available_dates: availableDates }), {
        status: 200,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    // 4. الأوقات المتاحة لتاريخ معين (الإضافة الجديدة المهمة)
    if (query_type === "available_times_for_date") {
      if (!date) {
        return new Response(JSON.stringify({ error: "التاريخ مطلوب" }), {
          status: 400,
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        });
      }

      const d = new Date(date);
      const dow = d.getDay();

      const { data: config, error: configError } = await supabase
        .from("working_hours")
        .select("is_closed, start_time, end_time, slot_duration_minutes, break_start, break_end")
        .eq("day_of_week", dow)
        .maybeSingle();

      if (configError) throw configError;
      if (!config || config.is_closed) {
        return new Response(JSON.stringify({ available_times: [] }), {
          status: 200,
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        });
      }

      // جلب المواعيد المحجوزة لهذا اليوم
      const { data: bookedData } = await supabase
        .from("appointments")
        .select("appointment_time")
        .eq("appointment_date", date);

      const booked = new Set(
        bookedData?.map(r => r.appointment_time.substring(0, 5)) || []
      );

      const startMin = timeToMinutes(config.start_time);
      const endMin   = timeToMinutes(config.end_time);
      const slotMin  = config.slot_duration_minutes || 15;

      const breakStart = config.break_start ? timeToMinutes(config.break_start) : null;
      const breakEnd   = config.break_end   ? timeToMinutes(config.break_end)   : null;

      // التحقق إذا كان اليوم الحالي لتجنب الأوقات الماضية
      const now = new Date();
      const isToday = now.toISOString().split("T")[0] === date;
      let minStart = startMin;

      if (isToday) {
        const currentMin = now.getHours() * 60 + now.getMinutes() + 60; // بعد ساعة
        const remainder = currentMin % slotMin;
        if (remainder !== 0) currentMin += slotMin - remainder;
        minStart = Math.max(currentMin, startMin);
      }

      const available: string[] = [];

      for (let m = minStart; m < endMin; m += slotMin) {
        const h = Math.floor(m / 60);
        const min = m % 60;
        const timeStr = `\( {h.toString().padStart(2, "0")}: \){min.toString().padStart(2, "0")}`;

        if (booked.has(timeStr)) continue;

        // استبعاد فترة الراحة
        if (breakStart !== null && breakEnd !== null && m >= breakStart && m < breakEnd) {
          continue;
        }

        available.push(timeStr);
      }

      return new Response(JSON.stringify({ available_times: available }), {
        status: 200,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    // 5. المواعيد المحجوزة (الافتراضي)
    if (query_type === "booked_times" || !query_type) {
      if (!date) {
        return new Response(JSON.stringify({ error: "التاريخ مطلوب" }), {
          status: 400,
          headers: { ...corsHeaders, "Content-Type": "application/json" },
        });
      }

      const { data, error } = await supabase
        .from("appointments")
        .select("appointment_time")
        .eq("appointment_date", date);

      if (error) throw error;

      const booked = (data || [])
        .map(row => row?.appointment_time?.substring(0, 5))
        .filter(Boolean);

      return new Response(JSON.stringify({ booked }), {
        status: 200,
        headers: { ...corsHeaders, "Content-Type": "application/json" },
      });
    }

    return new Response(JSON.stringify({ error: "نوع الاستعلام غير مدعوم" }), {
      status: 400,
      headers: { ...corsHeaders, "Content-Type": "application/json" },
    });

  } catch (err) {
    console.error("Edge Function error:", err?.stack ?? err);
    return new Response(
      JSON.stringify({ error: "خطأ داخلي في الخادم" }),
      { status: 500, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  }
});

// دالة مساعدة لتحويل الوقت إلى دقائق
function timeToMinutes(time: string): number {
  const [h, m] = time.split(":").map(Number);
  return h * 60 + m;
}
